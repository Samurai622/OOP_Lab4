<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OOP_Lab4.ViewModels"
        xmlns:t1="using:OOP_Lab4.Tasks.Task1" 
        xmlns:t2="using:OOP_Lab4.Tasks.Task2"
        x:Class="OOP_Lab4.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="OOP_Lab4 - Вибір завдань" Width="800" Height="450">

    <!-- Оновлені DataTemplates -->
    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type t1:Task1ViewModel}">
            <t1:Task1View />
        </DataTemplate>
        <DataTemplate DataType="{x:Type t2:Task2ViewModel}">
            <t2:Task2View />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="200, *">
        <!-- Бокове меню (залишається без змін) -->
        <Border Grid.Column="0" Background="#2D2D30" Padding="10">
            <StackPanel Spacing="10">
                <TextBlock Text="Меню завдань" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />
                
                <Button Content="Завдання 1" Command="{Binding ShowTask1Command}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Content="Завдання 2" Command="{Binding ShowTask2Command}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                
                <Border Height="1" Background="Gray" Margin="0,10" />
                
                <Button Content="Переглянути в веб" Command="{Binding OpenWebCommand}" 
                        Background="#007ACC" Foreground="White" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Основна робоча область -->
        <Border Grid.Column="1" Padding="20">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</Window>