<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OOP_Lab4.ViewModels"
        xmlns:t1="using:OOP_Lab4.Tasks.Task1" 
        xmlns:t2="using:OOP_Lab4.Tasks.Task2"
        xmlns:conv="using:OOP_Lab4.Converters" 
        x:Class="OOP_Lab4.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="OOP_Lab4 - Вибір завдань" Width="950" Height="550">

    <!-- ДОДАНО: Реєстрація конвертера -->
    <Window.Resources>
        <conv:BoolToColorConverter x:Key="ColorConverter" />
    </Window.Resources>

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type t1:Task1ViewModel}">
            <t1:Task1View />
        </DataTemplate>
        <DataTemplate DataType="{x:Type t2:Task2ViewModel}">
            <t2:Task2View />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="220, *">
        <!-- Бокове меню -->
        <Border Grid.Column="0" Background="#2D2D30" Padding="10">
            <StackPanel Spacing="10">
                <TextBlock Text="Меню завдань" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />
                
                <!-- ДОДАНО: Background="{Binding IsTask1Active, Converter={StaticResource ColorConverter}}" -->
                <Button Content="Завдання 1 (Варіант 2)" 
                        Command="{Binding ShowTask1Command}" 
                        Background="{Binding IsTask1Active, Converter={StaticResource ColorConverter}}"
                        Foreground="White"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        
                <!-- ДОДАНО: Background="{Binding IsTask2Active, Converter={StaticResource ColorConverter}}" -->
                <Button Content="Завдання 2 (Варіант 8)" 
                        Command="{Binding ShowTask2Command}" 
                        Background="{Binding IsTask2Active, Converter={StaticResource ColorConverter}}"
                        Foreground="White"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                
                <Border Height="1" Background="Gray" Margin="0,10" />
                
                <Button Content="Переглянути в веб" Command="{Binding OpenWebCommand}" 
                        Background="#4CAF50" Foreground="White" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>

                <!-- Кнопки JSON (Підготували місце для останнього кроку) -->
                <Button Content="Показати JSON" Click="ShowJson_Click"
                        Background="#FF9800" Foreground="White" Margin="0,20,0,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                
                <Button Content="Зберегти JSON в файл" Click="SaveJson_Click"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Основна робоча область -->
        <Border Grid.Column="1" Padding="20">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</Window>