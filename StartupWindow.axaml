<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OOP_Lab4.StartupWindow"
        Title="Вибір підключення" Width="450" Height="250" 
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">
        
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
        <TextBlock Text="Оберіть базу даних (API):" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        
        <Button Content="Локальна БД (localhost:3000)" 
                Click="LocalBtn_Click" 
                Background="#007ACC" Foreground="White" 
                Width="300" HorizontalContentAlignment="Center" Padding="10"/>
                
        <Button Content="Зовнішня БД (Хмарний сервер)" 
                Click="ExternalBtn_Click" 
                Background="#4CAF50" Foreground="White" 
                Width="300" HorizontalContentAlignment="Center" Padding="10"/>
                
        <TextBlock x:Name="InfoText" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </StackPanel>
</Window>