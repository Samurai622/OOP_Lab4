<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="clr-namespace:OOP_Lab4.Tasks.Task1"
            x:Class="OOP_Lab4.Tasks.Task1.Task1View"
            x:DataType="vm:Task1ViewModel">

 <Grid RowDefinitions="Auto, *, Auto" Margin="10">
  
   <!-- ВЕРХНЯ ПАНЕЛЬ: Канали -->
   <StackPanel Grid.Row="0" Margin="0,0,0,10" Spacing="10">
     <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
       <TextBlock Text="Вимірювальний канал:" FontWeight="Bold" VerticalAlignment="Center"/>
       <ComboBox ItemsSource="{Binding Channels}" SelectedItem="{Binding SelectedChannel}" Width="300">
         <ComboBox.ItemTemplate>
           <DataTemplate>
             <TextBlock Text="{Binding ShortInfo}" />
           </DataTemplate>
         </ComboBox.ItemTemplate>
       </ComboBox>
      
       <Button Content="➕ Створити" Command="{Binding AddChannelCommand}" />
       <Button Content="✏️ Редагувати" Command="{Binding EditChannelCommand}" />
       <Button Content="🗑 Видалити" Command="{Binding DeleteChannelCommand}" Background="#FF5555" Foreground="White" />
     </StackPanel>
   </StackPanel>

   <!-- ЦЕНТР: Пристрої (Лістбокс) -->
   <ListBox Grid.Row="1" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}">
     <ListBox.ItemTemplate>
       <DataTemplate>
         <StackPanel Orientation="Horizontal" Spacing="10">
           <TextBlock Text="{Binding LocationNumber, StringFormat='Номер місця: {0}'}" FontWeight="Bold"/>
           <TextBlock Text="|" />
           <TextBlock Text="{Binding CalibrationDate, StringFormat='Калібрування: {0}'}" />
           <TextBlock Text="|" />
           <TextBlock Text="{Binding Sensor.MagnitudeType, StringFormat='Тип: {0}'}" />
           <TextBlock Text="{Binding Sensor.CurrentValue, StringFormat='Поточне: {0}'}" Foreground="Blue" />
         </StackPanel>
       </DataTemplate>
     </ListBox.ItemTemplate>
   </ListBox>

   <!-- НИЖНЯ ПАНЕЛЬ: Кнопки пристроїв + Синхронізація -->
    <Grid Grid.Row="2" Margin="0,10,0,0" ColumnDefinitions="Auto, Auto, *">
      
      <Button Grid.Column="0" Content="🔄 Синхронізувати з БД" Command="{Binding SyncCommand}" Background="#4CAF50" Foreground="White"/>
      
      <!-- ДОДАНО: Текст статусу -->
      <TextBlock Grid.Column="1" Text="{Binding SyncStatusMessage}" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Yellow" FontWeight="Bold"/>
      
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
        <Button Content="Додати пристрій" Command="{Binding AddDeviceCommand}" />
        <Button Content="Редагувати пристрій" Command="{Binding EditDeviceCommand}" />
        <Button Content="Видалити пристрій" Command="{Binding DeleteDeviceCommand}" Background="#FF5555" Foreground="White"/>
      </StackPanel>
    </Grid>

 </Grid>
</UserControl>

