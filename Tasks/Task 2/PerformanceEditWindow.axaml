<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OOP_Lab4.Tasks.Task2"
        x:Class="OOP_Lab4.Tasks.Task2.PerformanceEditWindow"
        x:DataType="vm:PerformanceEditViewModel"
        Title="Редагування виступу" Width="400" Height="500" WindowStartupLocation="CenterOwner">
  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="{Binding Model.SequenceNumber, StringFormat='Порядковий номер виступу: {0}'}" FontWeight="Bold"/>
    
    <TextBlock Text="Ім'я учасника:" />
    <TextBox Text="{Binding Model.Participant.FirstName}" />
    <TextBlock Text="Прізвище учасника:" />
    <TextBox Text="{Binding Model.Participant.LastName}" />
    <TextBlock Text="Дата народження:" />
    <DatePicker SelectedDate="{Binding Model.Participant.BirthDate}" />

    <TextBlock Text="Командний виступ?" Margin="0,10,0,0"/>
    <CheckBox IsChecked="{Binding Model.IsTeam}" Content="Так (Командний)" />

    <TextBlock Text="Результат (Бали):" Margin="0,10,0,0"/>
    <TextBox Text="{Binding Model.ResultScore}" />

    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="Bold" TextWrapping="Wrap" Margin="0,10,0,0"/>

    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
      <Button Content="Зберегти і закрити" Command="{Binding SaveCommand}" />
      <Button Content="Скасувати" Command="{Binding CancelCommand}" />
    </StackPanel>
  </StackPanel>
</Window>