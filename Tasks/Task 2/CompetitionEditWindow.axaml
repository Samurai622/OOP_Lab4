<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OOP_Lab4.Tasks.Task2"
        x:Class="OOP_Lab4.Tasks.Task2.CompetitionEditWindow"
        x:DataType="vm:CompetitionEditViewModel"
        Title="Редагування змагання" Width="400" Height="250" WindowStartupLocation="CenterOwner">
  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Назва змагання:" FontWeight="Bold" />
    <TextBox Text="{Binding Model.Name}" Watermark="Введіть назву..." />
    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="Bold" TextWrapping="Wrap"/>
    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
      <Button Content="Зберегти і закрити" Command="{Binding SaveCommand}" />
      <Button Content="Скасувати і закрити" Command="{Binding CancelCommand}" />
    </StackPanel>
  </StackPanel>
</Window>